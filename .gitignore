tools/bin/

# Secrets / local config
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Multi-session coordination board — local scratchpad shared by live sessions, never committed
.claude/coord/

# Track O test-lock + invariant runtime state — local/ephemeral, never committed.
# (The manifest .claude/test.lock and the hook logic ARE committed — the shared toggle.)
.claude/test-unlocks/
.claude/reports/

# gated external benchmark data (GAIA etc.) — license-gated, never commit
go/internal/bench/banks/external/data/
